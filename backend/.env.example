# ============================================================================
# Smart Leads Backend Configuration
# Supports ALL deployment platforms: Vercel, Railway, Render, Docker, etc.
# ============================================================================

# Server port (auto-set by most platforms)
PORT=5000

# Environment: development or production
NODE_ENV=development

# ─── MongoDB Connection ────────────────────────────────────────────────────────
# Choose one based on your setup:

# Local development:
MONGO_URI=mongodb://localhost:27017/smart-leads

# OR MongoDB Atlas (cloud - recommended for production):
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/smart-leads?retryWrites=true&w=majority

# OR Docker Compose:
# MONGO_URI=mongodb://mongo:27017/smart-leads

# ─── JWT Secret (REQUIRED for production) ──────────────────────────────────────
# Generate: openssl rand -base64 32
# Minimum 32 characters
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Frontend CORS Origin (REQUIRED) ────────────────────────────────────────────
# Must match your frontend domain exactly
# Development: http://localhost:5173
# Production examples: https://your-project.vercel.app, https://your-app.onrender.com
CLIENT_URL=http://localhost:5173

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================================================
# See DEPLOYMENT_PLATFORMS.md for platform-specific setup instructions
# ============================================================================
